# 复制本文件为 .env 并填入你自己的值（.env 已被 .gitignore / .dockerignore 忽略，不会提交）
# docker compose 会自动读取 .env 作为变量来源

# JWT 签名密钥：请改成一段足够长且随机的字符串（生产必改）
JWT_SECRET=replace-with-a-long-random-secret-string

# 允许跨域的来源（单机同域部署填容器对外地址即可）
CORS_ORIGIN=http://localhost:4000

# 服务端口（容器内固定 4000，对外映射在 docker-compose.yml 的 ports 中设置）
PORT=4000
